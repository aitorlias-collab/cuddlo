# Shopify Storefront API (public — safe for client)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=tu_storefront_token

# Shopify Admin API (server-only — NEVER exponer al cliente)
# Obtener en: Shopify Admin → Settings → Apps and sales channels → Develop apps
# → Create an app → Configure Admin API scopes: write_draft_orders, read_draft_orders
# → Install app → Admin API access token
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Email — Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=hello@cuddlo.pet
RESEND_TO=hello@cuddlo.pet

# Panel de administración
ADMIN_PASSWORD=tu_password_seguro

# Cloudflare R2 (server-only)
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key
R2_BUCKET_NAME=cuddlo-renders
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
